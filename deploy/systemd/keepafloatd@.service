[Unit]
Description=keepAfloatD Raft VIP failover (optional front-end for NFS or other services)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
Environment=RUST_LOG=info
EnvironmentFile=-/etc/default/keepafloatd
ExecStart=/usr/bin/keepafloatd --config /etc/keepafloatd/config-%i.yaml
Restart=on-failure
RestartSec=1
TimeoutStopSec=15
AmbientCapabilities=CAP_NET_ADMIN CAP_NET_RAW

[Install]
WantedBy=multi-user.target
